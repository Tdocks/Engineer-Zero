# Supabase hosted learner data (optional — not required for personal Coding Developer)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe one-time per-track purchases (optional — not required for personal use)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_APPLIED_AI_OPERATIONS=
STRIPE_PRICE_IT_SUPPORT=
# Canonical public origin used for Stripe's success/cancel return URLs.
# Do not accept a browser-supplied redirect host.
APP_URL=

# Optional live Kyra provider — keep server-only
KYRA_PROVIDER_API_KEY=
KYRA_DAILY_LIMIT=10

# Optional live xAI Grok practice (Few-Day aio-lab-grok-live) — keep server-only.
# Never expose this key to the browser. Packet complete still works via deterministic fixtures.
XAI_API_KEY=
XAI_DAILY_LIMIT=30

# Isolated Coding Developer sandbox (separate process — never the Next.js server).
# Personal local Docker runner (recommended for solo practice):
CODING_SANDBOX_PERSONAL=true
CODING_SANDBOX_APPROVED=true
CODING_SANDBOX_ENDPOINT=http://127.0.0.1:8787/run
CODING_SANDBOX_TOKEN=dev-local-sandbox-token
#
# Hosted Hetzner (or any VPS) sandbox — HTTPS required:
# CODING_SANDBOX_PERSONAL=true
# CODING_SANDBOX_APPROVED=true
# CODING_SANDBOX_ENDPOINT=https://sandbox.engineer0.com/run
# CODING_SANDBOX_TOKEN=
# See sandbox/deploy/README.md

# GitHub App integration — keep all credentials server-only. The application
# stores installation/repository metadata, never user GitHub access tokens.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_SLUG=

# Source-review job protection. Set only in the hosting environment that runs
# the scheduled revalidation route.
SOURCE_REVALIDATION_SECRET=
# Vercel Cron uses this conventional name when it signs scheduled requests.
CRON_SECRET=
