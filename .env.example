# Supabase hosted learner data
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe one-time per-track purchases
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_APPLIED_AI_OPERATIONS=
STRIPE_PRICE_IT_SUPPORT=

# Optional live Kyra provider — keep server-only
KYRA_PROVIDER_API_KEY=
KYRA_DAILY_LIMIT=10

# Optional isolated Coding Developer sandbox. This must point to a separately
# operated, network-denied runner; never use the Next.js server as the runner.
# Leave this false until a qualified security review has verified every control
# in docs/CODING_SANDBOX_PROVIDER_CONTRACT.md.
CODING_SANDBOX_APPROVED=false
CODING_SANDBOX_ENDPOINT=
CODING_SANDBOX_TOKEN=

# GitHub App integration — keep all credentials server-only. The application
# stores installation/repository metadata, never user GitHub access tokens.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_SLUG=

# Source-review job protection. Set only in the hosting environment that runs
# the scheduled revalidation route.
SOURCE_REVALIDATION_SECRET=
